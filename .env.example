# Required
OPENAI_API_KEY=<your-openai-api-key>
QDRANT_URL=http://localhost:6333

# Optional — leave empty or omit for self-hosted Qdrant (no auth required)
QDRANT_API_KEY=

# Optional — additional embedding/LLM providers (leave blank to skip)
VOYAGE_API_KEY=
GEMINI_API_KEY=
COHERE_API_KEY=

# Optional — defaults shown
# QDRANT_COLLECTION_NAME=lapack-text-embedding-3-small
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536
# MAX_CHUNK_TOKENS=8191
# CHAT_MODEL=gpt-4.1-nano
# DATA_DIR=data/lapack
